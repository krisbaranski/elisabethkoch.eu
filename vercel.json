{
  "version": 2,
  "cleanUrls": false,
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/app/**"
    }
  },
  "routes": [
    {
      "src": "/(assets/.*|.*\\.(?:js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|webm|mp4))$",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
