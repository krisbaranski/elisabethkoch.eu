{
  "name": "elisabethkoch.eu",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration=production",
    "postbuild": "node -e \"const fs = require('fs'); const path = require('path'); const src = path.join('dist', 'app', 'browser', 'index.csr.html'); const dest = path.join('api', 'index.ssr.html'); if (fs.existsSync(src)) { fs.copyFileSync(src, dest); console.log('🌟 Vorlage erfolgreich in den api/-Ordner gespiegelt!'); } else { console.error('❌ Fehler: Quelldatei nicht gefunden unter ' + src); process.exit(1); }\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/material": "^17.3.10",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/platform-server": "^18.2.14",
    "@angular/router": "^18.2.14",
    "@angular/ssr": "^18.2.21",
    "@iframe-resizer/child": "^5.3.2",
    "@iframe-resizer/parent": "^5.3.2",
    "@ng-bootstrap/ng-bootstrap": "^16.0.0",
    "@ngx-translate/core": "^14.0.0",
    "@ngx-translate/http-loader": "^7.0.0",
    "@vercel/analytics": "^1.4.1",
    "bootstrap": "^5.3.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "mongodb": "^6.3.0",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.7"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "~18.2.21",
    "@angular/compiler-cli": "^18.2.14",
    "@bartholomej/ngx-translate-extract": "^8.0.2",
    "@types/express": "^4.17.25",
    "@types/jasmine": "~4.0.0",
    "@types/node": "^18.19.130",
    "angular-cli-ghpages": "^1.0.7",
    "browser-sync": "^3.0.0",
    "jasmine-core": "~4.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "typescript": "~5.4.5"
  },
  "overrides": {
    "@ng-bootstrap/ng-bootstrap": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core"
    }
  }
}
